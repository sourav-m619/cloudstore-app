# Copy this to .env — NEVER commit .env to Git
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Database — use "postgres" as host in docker-compose, "localhost" for direct
DB_HOST=postgres
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=localdev_password_123

# Security — minimum 32 characters
SECRET_KEY=local_dev_secret_key_minimum_32_chars_long

# CORS — comma separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000
